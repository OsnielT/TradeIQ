# HuggingFace fine-grained token with "Make calls to Inference Providers" permission enabled.
# Get one at https://huggingface.co/settings/tokens
VITE_HF_TOKEN=hf_your_token_here

# Twelve Data API key for chart market data (free: 800 req/day, 8 req/min)
# Get one at https://twelvedata.com (sign up → Dashboard → API Keys)
VITE_TWELVE_DATA_KEY=your_key_here
